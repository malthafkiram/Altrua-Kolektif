<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Campaign - Altrua Kolektif</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        textarea::placeholder,
        input::placeholder {
            color: white !important;
            opacity: 1;
        }
    </style>
</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #131e38 0%, #050814 100%); color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; padding: 40px 0;">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">


                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert border-0 text-white p-3 mb-4"
                        style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3) !important; border-radius: 12px; font-size: 0.9rem;">
                        <strong style="color: #ff6b6b;">⚠️ Validasi Gagal:</strong>
                        <%= error %>
                    </div>
                    <% } %>

                        <div
                            style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 20px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.3);">
                            <h3 class="fw-bold text-white mb-1">Registrasi Kampanye Baru</h3>
                            <p class="text-white small mb-4">Harap unggah berkas fisik dokumentasi asli lapangan.
                            </p>

                            <form action="/campaigns/add" method="POST" enctype="multipart/form-data">

                                <div class="mb-4">
                                    <label class="form-label small text-white fw-semibold">JUDUL UTAMA KAMPANYE</label>
                                    <input type="text" name="title" class="form-control text-white"
                                        placeholder="ex: Solidaritas Pembangunan Sanitasi Air" required
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                </div>

                                <div class="row g-4 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">KATEGORI UTAMA</label>
                                        <select name="category" class="form-select text-white" required
                                            style="background: rgba(13, 21, 39, 0.95); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                            <option value="" disabled selected style="color: #6c757d;">Pilih kategori...
                                            </option>
                                            <option value="Bencana" style="background: #0d1527;">Bencana Alam</option>
                                            <option value="Sosial" style="background: #0d1527;">Kemanusiaan / Sosial
                                            </option>
                                            <option value="Pendidikan" style="background: #0d1527;">Pendidikan</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">TARGET NOMINAL DANA
                                            (RP)</label>
                                        <input type="number" name="targetFunds" class="form-control text-white"
                                            placeholder="Minimal 1000000" required
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small text-white fw-semibold">FOTO BUKTI DOKUMENTASI (PNG /
                                        JPG)</label>
                                    <input type="file" name="image" class="form-control text-white"
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small text-white fw-semibold">DESKRIPSI LENGKAP KONDISI
                                        LAPANGAN</label>
                                    <textarea name="description" rows="4" class="form-control text-white"
                                        placeholder="Rincikan detail peristiwa serta alokasi peruntukan dana anggaran..."
                                        required
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none; resize: none;"></textarea>
                                </div>

                                <div class="d-flex gap-3 mt-5">
                                    <a href="/" class="btn w-50 py-3 text-white"
                                        style="background: rgba(255,255,255,0.05); border-radius: 10px; text-decoration: none; text-align: center; line-height: 1.5;">Batalkan</a>
                                    <button type="submit" class="btn w-50 py-3"
                                        style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; border-radius: 10px; box-shadow: 0 0 20px rgba(0, 242, 254, 0.4);">Publikasikan
                                        Konten</button>
                                </div>

                            </form>
                        </div>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>