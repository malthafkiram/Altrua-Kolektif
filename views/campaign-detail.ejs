<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= campaign.title %> - Altrua Ledger Transparency
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #131e38 0%, #050814 100%); color: #e2e8f0; min-height: 100vh;">

    <!-- NAVBAR SECTION -->
    <nav class="navbar navbar-expand-lg py-3 sticky-top"
        style="background: rgba(8, 13, 33, 0.7); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">
        <div class="container">
            <a class="navbar-brand fs-4" href="/" style="font-weight: 800; color: #ffffff; text-decoration: none;">
                ALTRUA<span style="color: #00f2fe; text-shadow: 0 0 15px rgba(0, 242, 254, 0.6);">.</span>
            </a>
            <div class="navbar-nav ms-auto align-items-center">
                <% if (user) { %>
                    <span class="me-3 small text-white">Logged as: <strong class="text-white">
                            <%= user.username %>
                        </strong></span>
                    <a href="/logout" class="btn btn-outline-danger btn-sm px-3 rounded-pill">Logout</a>
                    <% } else { %>
                        <a href="/login" class="text-white nav-link me-3">Login</a>
                        <a href="/register" class="btn btn-sm px-4 rounded-pill"
                            style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none;">Join
                            Platform</a>
                        <% } %>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTAINER -->
    <div class="container py-5">
        <div class="row g-5 mb-5">

            <!-- SISI KIRI: INFORMASI UTAMA KAMPANYE -->
            <div class="col-lg-7">
                <img src="/uploads/<%= campaign.image %>" class="img-fluid w-100 rounded-4 mb-4 shadow-lg"
                    alt="<%= campaign.title %>"
                    style="border: 1px solid rgba(255,255,255,0.08); max-height: 400px; object-fit: cover;">

                <div class="d-flex align-items-center gap-3 mb-3">
                    <span class="badge text-white" style="background: rgba(255,255,255,0.08); padding: 8px 14px;">
                        <%= campaign.category %>
                    </span>
                    <small style="color: #00f2fe; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">
                        <%= campaign.code %>
                    </small>
                </div>

                <h1 class="fw-bold text-white mb-3" style="font-size: 2.2rem;">
                    <%= campaign.title %>
                </h1>
                <p class="text-white small mb-4">Diorganisir oleh: <strong class="text-white">@<%=
                            campaign.User.username %></strong> (<%= campaign.User.email %>)</p>
                <p style="font-weight: 300; line-height: 1.7; color: #cbd5e1; text-align: justify;">
                    <%= campaign.description %>
                </p>
            </div>

            <!-- SISI KANAN: METRIKS FINANSIAL & TOMBOL DONASI -->
            <div class="col-lg-5">
                <div
                    style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 35px; position: sticky; top: 100px;">
                    <h4 class="fw-bold text-white mb-4" style="font-size: 1.25rem;">METRIKS DANA LEDGER</h4>

                    <div class="mb-2 text-white small">Target Penggalangan:</div>
                    <div class="fs-3 fw-bold text-white mb-4">
                        <%= toRupiah(campaign.targetFunds) %>
                    </div>

                    <div class="mb-2 text-white small">Dana Terkumpul Saat Ini:</div>
                    <div class="fs-3 fw-bold mb-2"
                        style="color: #00f2fe; text-shadow: 0 0 15px rgba(0, 242, 254, 0.3);">
                        <%= toRupiah(campaign.currentFunds) %>
                    </div>

                    <!-- FITUR BARU: Virtual Getter Sisa Kebutuhan Dana -->
                    <div class="mb-2 text-white small">Sisa Kebutuhan Dana (Virtual Getter):</div>
                    <div class="fs-5 fw-bold text-warning mb-3">
                        <%= toRupiah(campaign.remainingFunds) %>
                    </div>

                    <!-- FITUR BARU: Total Donatur dari Static Method -->
                    <div class="mb-3 small text-white">
                        Total Kontribusi Masuk: <strong class="text-white">
                            <%= totalDonors %> Transaksi
                        </strong>
                    </div>

                    <!-- Progress Bar Meter -->
                    <div class="progress mb-4" style="height: 6px; background: rgba(255,255,255,0.05);">
                        <div class="progress-bar" role="progressbar"
                            style="width: <%= campaign.percent %>%; background: linear-gradient(90deg, #0575e6, #00f2fe);">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between border-top border-secondary pt-3 mb-4"
                        style="border-color: rgba(255,255,255,0.1) !important;">
                        <span class="small text-white">Akurasi Capaian</span>
                        <span class="small fw-bold text-white">
                            <%= campaign.percent %>% Telah Terpenuhi
                        </span>
                    </div>

                    <!-- KONTROL AKSES TOMBOL KONTRIBUSI (RELEASE 4) -->
                    <% if (user && user.role==='donate' ) { %>
                        <!-- FITUR BARU: Tombol Mengarah Aktif ke Form Donasi -->
                        <a href="/campaigns/<%= campaign.id %>/donate"
                            class="btn w-100 py-3 fw-semibold text-center text-dark"
                            style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); border: none; border-radius: 12px; box-shadow: 0 0 20px rgba(0, 242, 254, 0.3); text-decoration: none; display: block;">
                            Salurkan Donasi Instan
                        </a>
                        <% } else if (user && user.role==='company' ) { %>
                            <div class="alert alert-warning small border-0 text-center text-white"
                                style="background: rgba(255, 193, 7, 0.1); border-radius: 10px;">
                                Penyelenggara tidak diperkenankan berdonasi pada kampanye sendiri.
                            </div>
                            <% } else { %>
                                <a href="/login" class="btn btn-outline-light w-100 py-3"
                                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                                    Masuk untuk Mulai Berdonasi
                                </a>
                                <% } %>
                </div>
            </div>
        </div>

        <!-- LOWER SECTION: MILESTONES & LIVE AUDIT LEDGER -->
        <div class="row g-5">

            <!-- SEKSI RENCANA ANGGARAN (MILESTONES) -->
            <div class="col-md-6">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-white mb-0" style="font-size: 1.4rem;">MILESTONES TRANSPARANSI (RAB)</h3>
                    <!-- FITUR BARU: Tombol Tambah RAB (Hanya muncul jika yang login adalah pemilik kampanye ini) -->
                    <% if (user && user.id===campaign.userId) { %>
                        <a href="/campaigns/<%= campaign.id %>/milestones/add"
                            class="btn btn-sm btn-outline-info rounded-pill px-3" style="text-decoration: none;">
                            + Tambah RAB
                        </a>
                        <% } %>
                </div>

                <% if (campaign.Milestones && campaign.Milestones.length> 0) { %>
                    <div class="d-flex flex-column gap-3">
                        <% campaign.Milestones.forEach(milestone=> { %>
                            <div
                                style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; padding: 20px;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-white fw-bold">TAHAP <%= milestone.stepNumber %></span>
                                    <% if (milestone.isVerified) { %>
                                        <span
                                            class="badge bg-success text-dark border border-success-subtle rounded-pill">Terverifikasi</span>
                                        <% } else { %>
                                            <span
                                                class="badge bg-warning text-dark border border-warning-subtle rounded-pill">Rencana
                                                Alokasi</span>
                                            <% } %>
                                </div>
                                <h5 class="fw-bold text-white mb-1">
                                    <%= toRupiah(milestone.targetAmount) %>
                                </h5>
                                <p class="text-white small mb-0" style="font-weight: 300;">
                                    <%= milestone.description %>
                                </p>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <p class="text-white small">Belum ada alokasi anggaran milestone yang terdaftar untuk kampanye
                            ini.</p>
                        <% } %>
            </div>

            <!-- SEKSI LIVE DONATION FEED -->
            <div class="col-md-6">
                <h3 class="fw-bold text-white mb-4" style="font-size: 1.4rem;">LIVE DONATION LEDGER FEED</h3>
                <div
                    style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 20px;">
                    <% if (campaign.UserDonations && campaign.UserDonations.length> 0) { %>
                        <div class="table-responsive">
                            <table class="table table-dark table-borderless align-middle mb-0"
                                style="--bs-table-bg: transparent;">
                                <thead>
                                    <tr class="text-white small"
                                        style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                                        <th>DONATUR</th>
                                        <th>NOMINAL</th>
                                        <th>PESAN DUKUNGAN</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% campaign.UserDonations.forEach(donation=> { %>
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                                            <td class="fw-bold text-white py-3">@<%= donation.User.username %>
                                            </td>
                                            <td style="color: #00f2fe; font-weight: 600;">
                                                <%= toRupiah(donation.amount) %>
                                            </td>
                                            <td class="text-white small" style="font-weight: 300;">
                                                <%= donation.comment || '-' %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div class="text-center py-4 text-white small">Belum ada riwayat kontribusi transaksi masuk
                                untuk kampanye ini.</div>
                            <% } %>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>