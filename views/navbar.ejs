<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Altrua Kolektif - Future of Universal Giving</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #131e38 0%, #050814 100%); color: #e2e8f0; overflow-x: hidden;">

    <nav class="navbar navbar-expand-lg py-3 sticky-top"
        style="background: rgba(8, 13, 33, 0.7); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(10px);">
        <div class="container">
            <a class="navbar-brand fs-4" href="/" style="font-weight: 800; color: #ffffff; text-decoration: none;">
                ALTRUA<span style="color: #00f2fe; text-shadow: 0 0 15px rgba(0, 242, 254, 0.6);">.</span>
            </a>


            <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                <form action="/" method="GET" class="d-flex mx-auto col-lg-5 my-3 my-lg-0">
                    <div class="input-group p-1 w-100"
                        style="background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 30px;">
                        <input type="text" name="search" class="form-control bg-transparent border-0 text-white ps-3"
                            value="<%= search || '' %>" style="box-shadow: none;">
                        <button class="btn rounded-circle p-0 d-flex align-items-center justify-content-center"
                            type="submit"
                            style="width: 38px; height: 38px; background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);">
                            ➔
                        </button>
                    </div>
                </form>

                <div class="navbar-nav align-items-center">
                    <% if (user) { %>
                        <span class="me-3 small text-white">Logged as: <strong class="text-white">
                                <%= user.username %>
                            </strong> (<%= user.role %>)</span>
                        <a href="/logout" class="btn btn-outline-danger btn-sm px-3 rounded-pill">Logout</a>
                        <% } else { %>
                            <a href="/login" class="btn me-4 px-4 rounded-pill btn-sm"
                                style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);">Login</a>
                            <a href="/register" class="btn px-4 rounded-pill btn-sm"
                                style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);">Join
                                Platform</a>
                            <% } %>
                </div>
            </div>
        </div>
    </nav>