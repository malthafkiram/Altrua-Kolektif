<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Altrua Kolektif - Gateway to Future Giving</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        textarea::placeholder,
        input::placeholder {
            color: white !important;
            opacity: 1;
        }
    </style>
</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #131e38 0%, #050814 100%); color: #e2e8f0; overflow-x: hidden;">

    <div class="position-absolute top-50 start-50 translate-middle rounded-circle"
        style="width: 400px; height: 400px; background: rgba(0, 242, 254, 0.08); filter: blur(100px); z-index: -1;">
    </div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8">

                <div class="text-center mb-4">
                    <a href="/"
                        style="font-weight: 800; color: #ffffff; text-decoration: none; font-size: 1.75rem; letter-spacing: 1px;">
                        ALTRUA<span style="color: #00f2fe; text-shadow: 0 0 15px rgba(0, 242, 254, 0.6);">.</span>
                    </a>
                    <p class="text-white small mt-2">Daftarkan akun kolektif masa depan Anda dalam hitungan detik.
                    </p>


                </div>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert border-0 text-white p-3 mb-4"
                        style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3) !important; border-radius: 12px; font-size: 0.9rem;">
                        <strong style="color: #ff6b6b;">Pendaftaran Gagal:</strong>
                        <%= error %>
                    </div>
                    <% } %>

                        <div
                            style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 24px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.3);">

                            <form action="/register" method="POST">

                                <div class="row g-4">
                                    <div class="col-12 mb-2">
                                        <h5
                                            style="color: #00f2fe; font-weight: 600; font-size: 1.1rem; text-shadow: 0 0 10px rgba(0, 242, 254, 0.3);">
                                            ACCOUNT CREDENTIALS
                                        </h5>
                                        <hr style="border-color: rgba(255,255,255,0.1); margin-top: 8px;">
                                    </div>



                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Username</label>
                                        <input type="text" name="username" class="form-control text-white"
                                            placeholder="ex: resky_dope"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Email Address</label>
                                        <input type="email" name="email" class="form-control text-white"
                                            placeholder="name@domain.com"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Password</label>
                                        <input type="password" name="password" class="form-control text-white"
                                            placeholder="masukkan password anda"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Platform Role</label>
                                        <select name="role" class="form-select text-white"
                                            style="background: rgba(13, 21, 39, 0.95); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                            <option value="" disabled selected style="color: #6c757d;">Pilih peran
                                                Anda...
                                            </option>
                                            <option value="donate" style="background: #0d1527;">Donate (Donatur /
                                                Filantropis)
                                            </option>
                                            <option value="company" style="background: #0d1527;">Company (Yayasan /
                                                Penyelenggara)</option>
                                        </select>
                                    </div>

                                    <div class="col-12 mt-5 mb-2">
                                        <h5
                                            style="color: #00f2fe; font-weight: 600; font-size: 1.1rem; text-shadow: 0 0 10px rgba(0, 242, 254, 0.3);">
                                            LEGAL PROFILE DETAILS
                                        </h5>
                                        <hr style="border-color: rgba(255,255,255,0.1); margin-top: 8px;">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Full Name / Institution
                                            Name</label>
                                        <input type="text" name="fullName" class="form-control text-white"
                                            placeholder="Nama lengkap sesuai identitas resmi"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                    </div>
                                    <!-- username, email, password, role, fullName, phoneNumber, address  -->
                                    <div class="col-md-6">
                                        <label class="form-label small text-white fw-semibold">Phone Number</label>
                                        <input type="text" name="phoneNumber" class="form-control text-white"
                                            placeholder="Contoh: 0852xxxxxxxx"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px;">
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label small text-white fw-semibold">Legal Address</label>
                                        <textarea name="address" rows="3" class="form-control text-white"
                                            placeholder="Alamat domisili lengkap atau kantor pusat operasional..."
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; resize: none;"></textarea>
                                    </div>
                                </div>

                                <div class="mt-5 text-center">
                                    <button type="submit" class="btn w-100 py-3 mb-3 fs-6"
                                        style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; border-radius: 12px; box-shadow: 0 0 25px rgba(0, 242, 254, 0.4); transition: all 0.3s ease;">
                                        Finalisasi & Buat Akun Kolektif
                                    </button>
                                    <p class="small text-white mb-0">Sudah terdaftar dalam ledger? <a href="/login"
                                            style="color: #00f2fe; text-decoration: none; font-weight: 600;">Masuk
                                            Sekarang</a>
                                    </p>
                                </div>

                            </form>

                        </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>