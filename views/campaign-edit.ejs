<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Campaign - Altrua Kolektif</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        textarea::placeholder,
        input::placeholder {
            color: white !important;
            opacity: 1;
        }
    </style>
</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #0d1527 0%, #050814 100%); color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; padding: 40px 0;">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- Alert Error Box Opsi B -->
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert border-0 text-white p-3 mb-4"
                        style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3) !important; border-radius: 12px; font-size: 0.9rem;">
                        <strong style="color: #ff6b6b;">⚠️ Pembaruan Gagal:</strong>
                        <%= error %>
                    </div>
                    <% } %>

                        <div
                            style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 20px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.3);">
                            <h3 class="fw-bold text-white mb-1">Perbarui Data Kampanye</h3>
                            <p class="text-secondary small mb-4">ID Konten: <span style="color: #00f2fe;">
                                    <%= campaign.code %>
                                </span></p>

                            <form action="/campaigns/<%= campaign.id %>/edit" method="POST"
                                enctype="multipart/form-data">

                                <div class="mb-4">
                                    <label class="form-label small text-muted fw-semibold">JUDUL UTAMA KAMPANYE</label>
                                    <input type="text" name="title" class="form-control text-white"
                                        value="<%= campaign.title %>" required
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                </div>

                                <div class="row g-4 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small text-muted fw-semibold">KATEGORI UTAMA</label>
                                        <select name="category" class="form-select text-white" required
                                            style="background: rgba(13, 21, 39, 0.95); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                            <option value="Bencana" <%=campaign.category==='Bencana' ? 'selected' : ''
                                                %> style="background: #0d1527;">Bencana Alam</option>
                                            <option value="Sosial" <%=campaign.category==='Sosial' ? 'selected' : '' %>
                                                style="background: #0d1527;">Kemanusiaan / Sosial</option>
                                            <option value="Pendidikan" <%=campaign.category==='Pendidikan' ? 'selected'
                                                : '' %> style="background: #0d1527;">Pendidikan</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small text-muted fw-semibold">TARGET NOMINAL DANA
                                            (RP)</label>
                                        <input type="number" name="targetFunds" class="form-control text-white"
                                            value="<%= campaign.targetFunds %>" required
                                            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small text-muted fw-semibold">GANTI FOTO (Biarkan kosong
                                        jika tetap menggunakan foto lama)</label>
                                    <input type="file" name="image" class="form-control text-white"
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                                    <small class="text-secondary d-block mt-2">File saat ini: <%= campaign.image %>
                                    </small>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small text-muted fw-semibold">DESKRIPSI LENGKAP KONDISI
                                        LAPANGAN</label>
                                    <textarea name="description" rows="4" class="form-control text-white" required
                                        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none; resize: none;"><%= campaign.description %></textarea>
                                </div>

                                <div class="d-flex gap-3 mt-5">
                                    <a href="/campaigns/<%= campaign.id %>" class="btn w-50 py-3 text-white"
                                        style="background: rgba(255,255,255,0.05); border-radius: 10px; text-decoration: none; text-align: center; line-height: 1.5;">Kembali</a>
                                    <button type="submit" class="btn w-50 py-3"
                                        style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; border-radius: 10px; box-shadow: 0 0 20px rgba(0, 242, 254, 0.4);">Simpan
                                        Perubahan</button>
                                </div>

                            </form>
                        </div>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>