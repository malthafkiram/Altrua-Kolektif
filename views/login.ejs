<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login to Altrua Kolektif</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        textarea::placeholder,
        input::placeholder {
            color: white !important;
            opacity: 1;
        }
    </style>


</head>

<body
    style="font-family: 'Inter', sans-serif; background: radial-gradient(circle at 50% 0%, #131e38 0%, #050814 100%); color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px 0; overflow-x: hidden;">

    <div class="position-absolute top-50 start-50 translate-middle rounded-circle"
        style="width: 350px; height: 350px; background: rgba(0, 242, 254, 0.06); filter: blur(90px); z-index: -1;">
    </div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">

                <div class="text-center mb-4">
                    <a href="/"
                        style="font-weight: 800; color: #ffffff; text-decoration: none; font-size: 1.75rem; letter-spacing: 1px;">
                        ALTRUA<span style="color: #00f2fe; text-shadow: 0 0 15px rgba(0, 242, 254, 0.6);">.</span>
                    </a>
                    <p class="text-white small mt-2">Masukkan kredensial terenkripsi Anda untuk mengelola platform.
                    </p>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert border-0 text-white p-3 mb-4"
                            style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3) !important; border-radius: 12px; font-size: 0.9rem;">
                            <strong style="color: #ff6b6b;">Akses Ditolak:</strong>
                            <%= error %>
                        </div>
                        <% } %>
                </div>

                <div
                    style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 20px; padding: 35px; box-shadow: 0 20px 50px rgba(0,0,0,0.4);">

                    <form action="/login" method="POST">

                        <div class="mb-4">
                            <label class="form-label small text-white fw-semibold" style="letter-spacing: 0.5px;">SECURE
                                EMAIL ADDRESS</label>
                            <input type="email" name="email" class="form-control text-white"
                                placeholder="name@domain.com"
                                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label small text-white fw-semibold mb-0"
                                    style="letter-spacing: 0.5px;">ACCOUNT PASSWORD</label>
                            </div>
                            <input type="password" name="password" class="form-control text-white"
                                placeholder="••••••••"
                                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 12px; box-shadow: none;">
                        </div>

                        <div class="mb-4 form-check d-flex align-items-center">
                            <input type="checkbox" class="form-check-input bg-transparent border-secondary"
                                id="rememberMe" style="box-shadow: none; cursor: pointer;">
                            <label class="form-check-label small text-white ms-2" for="rememberMe"
                                style="cursor: pointer; user-select: none;">Ingat session perangkat ini</label>
                        </div>

                        <button type="submit" class="btn w-100 py-3 mb-3 fs-6"
                            style="background: linear-gradient(135deg, #0575e6 0%, #00f2fe 100%); color: #050814; font-weight: 600; border: none; border-radius: 10px; box-shadow: 0 0 20px rgba(0, 242, 254, 0.4); transition: all 0.3s ease;">
                            Otentikasi & Masuk ➔
                        </button>

                        <div class="text-center mt-4">
                            <p class="small text-white mb-0">Belum memiliki akses ledger? <a href="/register"
                                    style="color: #00f2fe; text-decoration: none; font-weight: 600;">Buat Akun Baru</a>
                            </p>
                        </div>

                    </form>

                </div>

                <div class="text-center mt-4">
                    <a href="/" class="small text-white" style="text-decoration: none; transition: color 0.3s;">←
                        Kembali ke Beranda Utama</a>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>