<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kirim Kontribusi Dana - Altrua Ledger</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        textarea::placeholder,
        input::placeholder {
            color: white !important;
            opacity: 1;
        }
    </style>
</head>

<body
    style="font-family: sans-serif; background: radial-gradient(circle at 50% 0%, #0d1527 0%, #050814 100%); color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; padding: 20px 0;">
    <div class="container col-md-5">
        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert bg-danger text-white border-0 p-3 mb-3" style="border-radius: 10px;">
                <%= error %>
            </div>
            <% } %>
                <div
                    style="background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.07); border-radius: 20px; padding: 35px;">
                    <h4 class="text-white fw-bold mb-4">Salurkan Donasi</h4>
                    <form action="/campaigns/<%= campaignId %>/donate" method="POST">
                        <div class="mb-4">
                            <label class="form-label small text-white">NOMINAL DANA (RP)</label>
                            <input type="number" name="amount" class="form-control text-white"
                                placeholder="Contoh: 50000" required
                                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); padding: 12px; box-shadow: none;">
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-white">PESAN DUKUNGAN (OPSIONAL)</label>
                            <textarea name="comment" rows="3" class="form-control text-white"
                                placeholder="Tulis doa atau pesan hangat Anda..."
                                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); padding: 12px; box-shadow: none; resize: none;"></textarea>
                        </div>
                        <button type="submit" class="btn w-100 py-3 text-dark fw-bold"
                            style="background: linear-gradient(135deg, #0575e6, #00f2fe); border: none; border-radius: 10px;">Kirim
                            Transaksi Berdonasi</button>
                    </form>
                </div>
    </div>
</body>

</html>